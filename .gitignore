.DS_Store
.env
*.log

# Python
__pycache__/
.pytest_cache/
.venv/

# Sensitive Vault generated evidence
evidence/*.json
evidence/*.crt
evidence/*.pem
evidence/*.txt

# Allow clean markdown evidence
!evidence/*.md

# Keep screenshots folder
!evidence/screenshots/
!evidence/screenshots/.gitkeep

# Terraform local files and state
.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
